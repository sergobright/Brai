{% for name, env in brai_envs.items() %}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl restart {{ env.service }}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl stop {{ env.service }}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl restart {{ env.admin_service }}
{% for agent_name, agent in brai_goal_agents.items() %}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl restart {{ agent.unit_base }}{{ env.goal_agent_service_suffix }}.service
{% if name in ['prod', 'dev'] %}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl enable --now {{ agent.unit_base }}{{ env.goal_agent_service_suffix }}.service
{% endif %}
{% if name.startswith('preview-') %}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl stop {{ agent.unit_base }}{{ env.goal_agent_service_suffix }}.service
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl reset-failed {{ agent.unit_base }}{{ env.goal_agent_service_suffix }}.service
{% endif %}
{% endfor %}
{% if name.startswith('preview-') %}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl stop {{ env.admin_service }}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl reset-failed {{ env.service }}
{{ brai_deploy_user }} ALL=(root) NOPASSWD: /bin/systemctl reset-failed {{ env.admin_service }}
{% endif %}
{% endfor %}
