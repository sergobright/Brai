{
  "id": "activity.classifier",
  "version": "1",
  "workflow_definition_version": 1,
  "worker_build_id": "activity-classifier.v1",
  "workflow_type": "ActivityClassifierWorkflow",
  "queue_base": "brai-agent-activity-classifier",
  "entrypoint": "src/entrypoints/activity-classifier.mjs",
  "input_schema_version": "brai.goal-agent.input.v1",
  "prompt_version": "activity-classifier.v1",
  "output_schema_version": "brai.activity-classifier.result.v1",
  "model_env": "BRAI_ACTIVITY_CLASSIFIER_MODEL",
  "default_model": "gpt-5.4-mini",
  "timeout_ms": 60000,
  "retry": { "schema_attempts": 3 },
  "decision_kinds": ["activity_type_change"],
  "review_only": false,
  "prompt": "Определи семантический тип одной записи. Action — один исполнимый шаг. Goal — желаемый результат, которому разумно нужны минимум два шага. Для незадачного или сомнительного Inbox верни no_change. Forced Operation никогда не конвертируй. Используй только переданные Item ID и короткое проверяемое обоснование.",
  "output_schema": {
    "type": "object",
    "required": ["schema_version", "agent_id", "agent_version", "decisions"],
    "additionalProperties": false,
    "properties": {
      "schema_version": { "type": "string", "const": "1" },
      "agent_id": { "type": "string", "const": "activity.classifier" },
      "agent_version": { "type": "string", "const": "1" },
      "decisions": {
        "type": "array",
        "maxItems": 1,
        "items": {
          "type": "object",
          "required": ["decision_kind", "subject_items_id", "confidence", "rationale", "evidence", "proposal"],
          "additionalProperties": false,
          "properties": {
            "decision_kind": { "type": "string", "const": "activity_type_change" },
            "subject_items_id": { "type": "string", "minLength": 1, "maxLength": 128 },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "rationale": { "type": "string", "minLength": 1, "maxLength": 500 },
            "evidence": {
              "type": "array",
              "minItems": 1,
              "maxItems": 5,
              "items": {
                "type": "object",
                "required": ["items_id", "field", "excerpt"],
                "additionalProperties": false,
                "properties": {
                  "items_id": { "type": "string", "minLength": 1, "maxLength": 128 },
                  "field": { "type": "string", "enum": ["title", "description_md", "reason", "normalization"] },
                  "excerpt": { "type": "string", "minLength": 1, "maxLength": 200 }
                }
              }
            },
            "proposal": {
              "type": "object",
              "required": ["current_role", "current_type", "target_type", "end_inbox_role"],
              "additionalProperties": false,
              "properties": {
                "current_role": { "type": "string", "enum": ["activity", "inbox"] },
                "current_type": { "type": "string", "enum": ["action", "inbox"] },
                "target_type": { "type": "string", "enum": ["action", "goal", "no_change"] },
                "end_inbox_role": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
